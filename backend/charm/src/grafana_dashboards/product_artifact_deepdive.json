        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "12.0.2",
      "targets": [
        {
          "expr": "sum by (status) (test_observer_test_results{artefact_name=~\"$artefact\", track=~\"$track\", artefact_stage=~\"$stage\", family=~\"$family\"})",
